{
    "name": "renesance",
    "version": "2.0.0",
    "description": "Renesance — TTS Asset Recovery Tool",
    "main": "renesance-app.js",
    "bin": "renesance-app.js",
    "scripts": {
        "start": "node renesance-app.js",
        "pack": "pkg . --targets node18-win-x64 --output dist/Renesance.exe"
    },
    "pkg": {
        "assets": [
            "renesance_cube.lua"
        ],
        "outputPath": "dist"
    },
    "devDependencies": {
        "pkg": "^5.8.1"
    }
}